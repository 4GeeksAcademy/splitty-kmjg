# =========================================
# SUPABASE CONFIGURATION
# =========================================
# Get these from your Supabase project:
# https://app.supabase.com -> Project Settings -> Configuration

# PostgreSQL connection string (for SQLAlchemy)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase JWT configuration (for Auth)
JWT_SECRET_KEY="[your-supabase-jwt-secret]"
SUPABASE_JWT_SECRET="[same-as-above]"

# =========================================
# EXISTING CONFIG (keep these)
# =========================================

FLASK_DEBUG=1
FLASK_ENV=development
PORT=3001

# Cloudinary (for receipt uploads - keep using Cloudinary or migrate to Supabase Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mail (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=
MAIL_PASSWORD=

# =========================================
# OPTIONAL: Supabase Storage (alternative to Cloudinary)
# =========================================
# If using Supabase Storage instead of Cloudinary for receipts:
# SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# SUPABASE_ANON_KEY="[your-anon-key]"
# SUPABASE_SERVICE_KEY="[your-service-key]"
