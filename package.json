{
	"name": "splitty-kmjg",
	"engines": {
		"node": ">=20.0.0"
	},
	"version": "1.0.1",
	"description": "",
	"main": "index.js",
	"scripts": {
		"start:frontend": "vite",
		"start:backend": "cmd /c \"set FLASK_APP=src/app.py && set FLASK_DEBUG=1 && .venv\\Scripts\\python.exe -m flask run -p 3001\"",
		"start:tunnel": "cloudflared tunnel --url http://localhost:3000",
		"dev": "concurrently -c \"cyan,magenta,yellow\" -n \"vite,backend,cloudflare\" \"npm run start:frontend\" \"npm run start:backend\" \"npm run start:tunnel\"",
		"start": "vite",
		"build": "vite build",
		"lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview"
	},
	"author": {
		"name": "Alejandro Sanchez",
		"url": "http://alesanchezr.com/"
	},
	"contributors": [
		{
			"name": "Alejandro Sanchez",
			"url": "http://alesanchezr.com/"
		},
		{
			"name": "Ignacio Cordoba",
			"url": "http://github.com/nachovz"
		}
	],
	"license": "ISC",
	"devDependencies": {
		"@types/react": "^18.2.18",
		"@types/react-dom": "^18.2.7",
		"@vitejs/plugin-react": "^4.0.4",
		"concurrently": "^9.2.1",
		"eslint": "^8.46.0",
		"eslint-plugin-react": "^7.33.1",
		"eslint-plugin-react-hooks": "^4.6.0",
		"eslint-plugin-react-refresh": "^0.4.3",
		"install": "^0.13.0",
		"supabase": "^2.85.0",
		"vite": "^4.4.8"
	},
	"babel": {
		"presets": [
			"@babel/preset-env",
			"@babel/preset-react"
		],
		"plugins": [
			"@babel/plugin-proposal-class-properties",
			[
				"@babel/plugin-transform-runtime",
				{
					"regenerator": true
				}
			]
		]
	},
	"dependencies": {
		"@gsap/react": "^2.1.2",
		"@paypal/react-paypal-js": "^9.1.1",
		"@supabase/supabase-js": "^2.101.1",
		"gsap": "^3.14.2",
		"motion": "^12.35.1",
		"prop-types": "^15.8.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-router-dom": "^6.18.0",
		"react-type-animation": "^3.2.0"
	}
